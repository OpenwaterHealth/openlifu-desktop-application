execute_process(
  COMMAND
    "@PYTHON_EXECUTABLE@"
      "@OPENLIFU_PYTHON_ENVIRONMENT_GENERATOR@"
      --target-python "@PYTHON_EXECUTABLE@"
      --tool-dir "@OPENLIFU_PYTHON_ENVIRONMENT_TOOLS_DIR@"
      --tool-lock-hash "@OPENLIFU_PYTHON_ENVIRONMENT_TOOLS_LOCK_HASH@"
      --output-dir "@OPENLIFU_PYTHON_ENVIRONMENT_OUTPUT_DIR@"
      --forbidden-path "@CMAKE_BINARY_DIR@"
      --forbidden-path "@CMAKE_CURRENT_SOURCE_DIR@"
      --forbidden-path "@Slicer_MAIN_PROJECT_SOURCE_DIR@"
  RESULT_VARIABLE _generation_result
  )

if(_generation_result STREQUAL "0")
  message(STATUS
    "Generated pip and CycloneDX Python environment artifacts in "
    "@OPENLIFU_PYTHON_ENVIRONMENT_OUTPUT_DIR@"
    )
elseif(_generation_result STREQUAL "2")
  if(DEFINED CMAKE_INSTALL_PREFIX AND NOT CMAKE_INSTALL_PREFIX STREQUAL "")
    set(_installed_metadata_dir
      "$ENV{DESTDIR}${CMAKE_INSTALL_PREFIX}/@Slicer_INSTALL_SHARE_DIR@/BuildMetadata"
      )
    file(REMOVE "${_installed_metadata_dir}/python-environment.cdx.json")
  endif()
  message(WARNING
    "Generated the pip Python environment artifact, but omitted the optional "
    "CycloneDX artifact. See the preceding warning for details."
    )
else()
  message(FATAL_ERROR
    "Failed to generate the required pip Python environment artifact "
    "(result: ${_generation_result})."
    )
endif()
